Grammar

    0 $accept: start $end

    1 start: compilation_units
    2      | free_form

    3 compilation_units: compilation_unit
    4                  | compilation_units compilation_unit

    5 compilation_unit: program_unit
    6                 | module_unit

    7 free_form: preamble declarations executables

    8 program_unit: PROGRAM IDENTIFIER program_body END PROGRAM IDENTIFIER
    9             | PROGRAM IDENTIFIER program_body END PROGRAM

   10 module_unit: MODULE IDENTIFIER module_body END MODULE IDENTIFIER
   11            | MODULE IDENTIFIER module_body END MODULE

   12 program_body: preamble declarations executables contains_block

   13 module_body: preamble declarations executables contains_block

   14 $@1: ε

   15 contains_block: CONTAINS $@1 subprogram_list
   16               | ε

   17 declarations: ε
   18             | declaration declarations

   19 preamble: ε
   20         | preamble pp_item

   21 pp_item: pp_define_undef
   22        | pp_if_block

   23 declaration: type_spec declaration_attributes DECL_SEP declarator_list
   24            | IMPLICIT NONE
   25            | USE identifier
   26            | type_def

   27 type_spec: INTEGER
   28          | REAL
   29          | LOGICAL
   30          | char_type_spec
   31          | TYPE LPAREN identifier RPAREN
   32          | CLASS identifier
   33          | COMPLEX

   34 char_type_spec: CHARACTER char_len_opt

   35 char_len_opt: ε
   36             | LPAREN LENGTH_SPECIFIER ASSIGN char_len_value RPAREN

   37 char_len_value: COLON
   38               | INT_CONST
   39               | identifier

   40 attributes: attribute
   41           | attribute COMMA attributes

   42 attribute: ALLOCATABLE
   43          | POINTER
   44          | TARGET
   45          | INTENT LPAREN IN RPAREN
   46          | INTENT LPAREN OUT RPAREN
   47          | INTENT LPAREN INOUT RPAREN

   48 declaration_attributes: ε
   49                       | COMMA attributes

   50 identifier_list: identifier
   51                | identifier COMMA identifier_list

   52 declarator_list: declarator
   53                | declarator COMMA declarator_list

   54 $@2: ε

   55 declarator: identifier array_spec_opt $@2 init_opt

   56 array_spec_opt: ε
   57               | array_spec

   58 array_spec: LPAREN array_spec_list RPAREN

   59 array_spec_list: array_spec_item
   60                | array_spec_list COMMA array_spec_item

   61 array_spec_item: ASSUMED_RANK_SPECIFIER
   62                | COLON
   63                | expression
   64                | expression COLON
   65                | COLON expression
   66                | expression COLON expression

   67 init_opt: ε
   68         | ASSIGN expression

   69 executables: ε
   70            | executables executable

   71 executable: assignment_stmt
   72           | if_stmt
   73           | print_stmt
   74           | allocate_stmt
   75           | deallocate_stmt
   76           | do_stmt
   77           | dowhile_stmt
   78           | select_rank_stmt
   79           | select_stmt
   80           | call_stmt
   81           | return_stmt
   82           | stop_stmt
   83           | pointer_stmt

   84 assignment_stmt: variable_ref ASSIGN expression

   85 $@3: ε

   86 $@4: ε

   87 if_stmt: IF LPAREN expression RPAREN THEN $@3 executables ELSE $@4 executables ENDIF

   88 $@5: ε

   89 do_stmt: DO IDENTIFIER ASSIGN expression COMMA expression step_opt $@5 executables END DO

   90 $@6: ε

   91 $@7: ε

   92 dowhile_stmt: DO WHILE LPAREN $@6 expression RPAREN $@7 executables END DO

   93 $@8: ε

   94 select_stmt: SELECT CASE LPAREN expression RPAREN $@8 case_blocks END SELECT

   95 $@9: ε

   96 select_rank_stmt: SELECT RANK LPAREN identifier RPAREN $@9 rank_blocks END SELECT

   97 rank_blocks: rank_block
   98            | rank_blocks rank_block

   99 $@10: ε

  100 rank_block: RANK LPAREN rank_selector RPAREN $@10 executables

  101 $@11: ε

  102 rank_block: RANK DEFAULT $@11 executables

  103 rank_selector: INT_CONST
  104              | MUL_OP

  105 case_blocks: case_block
  106            | case_blocks case_block

  107 $@12: ε

  108 case_block: CASE LPAREN expression RPAREN $@12 executables

  109 $@13: ε

  110 case_block: CASE DEFAULT $@13 executables

  111 call_stmt: CALL callable_name LPAREN argument_values RPAREN

  112 callable_name: identifier
  113              | INTRINSIC

  114 return_stmt: RETURN

  115 stop_stmt: STOP
  116          | STOP INT_CONST
  117          | STOP STRING

  118 pointer_stmt: variable_ref PTR_ASSIGN variable_ref

  119 step_opt: ε
  120         | COMMA expression

  121 print_stmt: PRINT MUL_OP COMMA print_args

  122 print_args: expression
  123           | print_args COMMA expression

  124 allocate_stmt: ALLOCATE LPAREN argument_values RPAREN

  125 deallocate_stmt: DEALLOCATE LPAREN argument_values RPAREN

  126 expression: expression ADD_OP expression
  127           | expression MUL_OP expression
  128           | expression EXPONENT expression
  129           | expression REL_OP expression
  130           | expression LOGICAL_OP expression
  131           | factor
  132           | ADD_OP expression
  133           | LOGICAL_OP expression

  134 factor: primary

  135 primary: INT_CONST
  136        | REAL_CONST
  137        | LOGICAL_CONST
  138        | STRING
  139        | complex_literal
  140        | LPAREN expression RPAREN
  141        | variable_ref primary_suffix_opt

  142 complex_literal: LPAREN expression COMMA expression RPAREN

  143 primary_suffix_opt: ε
  144                   | LPAREN argument_values RPAREN

  145 variable_ref: identifier
  146             | variable_ref DERIVED_TYPE_COMPONENT identifier

  147 subprogram_list: ε
  148                | subprogram_list subprogram

  149 subprogram: SUBROUTINE identifier LPAREN identifier_list_opt RPAREN program_body END SUBROUTINE
  150           | SUBROUTINE identifier LPAREN identifier_list_opt RPAREN program_body END SUBROUTINE identifier
  151           | FUNCTION identifier LPAREN identifier_list_opt RPAREN program_body END FUNCTION
  152           | FUNCTION identifier LPAREN identifier_list_opt RPAREN program_body END FUNCTION identifier
  153           | RECURSIVE FUNCTION identifier LPAREN identifier_list_opt RPAREN RESULT LPAREN identifier RPAREN program_body END FUNCTION
  154           | RECURSIVE FUNCTION identifier LPAREN identifier_list_opt RPAREN RESULT LPAREN identifier RPAREN program_body END FUNCTION identifier

  155 argument_values: ε
  156                | expression
  157                | expression COMMA argument_values

  158 identifier_list_opt: ε
  159                    | identifier_list

  160 identifier: IDENTIFIER
  161           | RESULT

  162 type_def: TYPE DECL_SEP identifier type_def_body END_TYPE identifier

  163 type_def_body: ε
  164              | type_def_declarations

  165 type_def_declarations: type_def_declaration
  166                      | type_def_declarations type_def_declaration

  167 type_def_declaration: type_spec declaration_attributes DECL_SEP declarator_list

  168 pp_define_undef: PP_DEFINE identifier
  169                | PP_DEFINE identifier INT_CONST
  170                | PP_UNDEF identifier

  171 pp_if_block: PP_IFDEF identifier declarations pp_else_opt PP_ENDIF
  172            | PP_IFNDEF identifier declarations pp_else_opt PP_ENDIF
  173            | PP_IF identifier declarations pp_else_opt PP_ENDIF
  174            | PP_IF INT_CONST declarations pp_else_opt PP_ENDIF

  175 pp_else_opt: ε
  176            | PP_ELSE declarations


