Grammar

    0 $accept: start $end

    1 start: compilation_units
    2      | free_form

    3 compilation_units: compilation_unit
    4                  | compilation_units compilation_unit

    5 compilation_unit: program_unit
    6                 | module_unit

    7 free_form: preamble declarations executables

    8 $@1: ε

    9 program_unit: PROGRAM IDENTIFIER $@1 program_body END PROGRAM opt_identifier

   10 $@2: ε

   11 module_unit: MODULE IDENTIFIER $@2 module_body END MODULE opt_identifier

   12 program_body: preamble declarations executables contains_block

   13 module_body: preamble declarations executables contains_block

   14 contains_block: CONTAINS subprogram_list
   15               | ε

   16 declarations: ε
   17             | declaration declarations

   18 preamble: ε
   19         | preamble pp_item

   20 pp_item: pp_define_undef
   21        | pp_if_block

   22 declaration: type_spec declaration_attributes DECL_SEP declarator_list
   23            | IMPLICIT NONE
   24            | USE identifier
   25            | type_def

   26 type_spec: INTEGER
   27          | REAL
   28          | LOGICAL
   29          | char_type_spec
   30          | TYPE LPAREN identifier RPAREN
   31          | CLASS identifier
   32          | COMPLEX

   33 char_type_spec: CHARACTER char_len_opt

   34 char_len_opt: ε
   35             | LPAREN LENGTH_SPECIFIER ASSIGN char_len_value RPAREN

   36 char_len_value: COLON
   37               | INT_CONST
   38               | identifier

   39 attributes: attribute
   40           | attribute COMMA attributes

   41 attribute: ALLOCATABLE
   42          | POINTER
   43          | TARGET
   44          | INTENT LPAREN IN RPAREN
   45          | INTENT LPAREN OUT RPAREN
   46          | INTENT LPAREN INOUT RPAREN

   47 declaration_attributes: ε
   48                       | COMMA attributes

   49 identifier_list: identifier
   50                | identifier COMMA identifier_list

   51 declarator_list: declarator
   52                | declarator COMMA declarator_list

   53 $@3: ε

   54 declarator: identifier array_spec_opt $@3 init_opt

   55 array_spec_opt: ε
   56               | array_spec

   57 array_spec: LPAREN array_spec_list RPAREN

   58 array_spec_list: array_spec_item
   59                | array_spec_list COMMA array_spec_item

   60 array_spec_item: ASSUMED_RANK_SPECIFIER
   61                | COLON
   62                | expression
   63                | expression COLON
   64                | COLON expression
   65                | expression COLON expression

   66 init_opt: ε
   67         | ASSIGN expression

   68 executables: ε
   69            | executables executable

   70 executable: assignment_stmt
   71           | if_stmt
   72           | print_stmt
   73           | allocate_stmt
   74           | deallocate_stmt
   75           | do_stmt
   76           | dowhile_stmt
   77           | select_rank_stmt
   78           | select_stmt
   79           | call_stmt
   80           | return_stmt
   81           | stop_stmt
   82           | pointer_stmt

   83 assignment_stmt: variable_ref ASSIGN expression

   84 $@4: ε

   85 $@5: ε

   86 if_stmt: IF LPAREN expression RPAREN THEN $@4 executables ELSE $@5 executables ENDIF

   87 $@6: ε

   88 do_stmt: DO IDENTIFIER ASSIGN expression COMMA expression step_opt $@6 executables END DO

   89 $@7: ε

   90 $@8: ε

   91 dowhile_stmt: DO WHILE LPAREN $@7 expression RPAREN $@8 executables END DO

   92 $@9: ε

   93 select_stmt: SELECT CASE LPAREN expression RPAREN $@9 case_blocks END SELECT

   94 $@10: ε

   95 select_rank_stmt: SELECT RANK LPAREN identifier RPAREN $@10 rank_blocks END SELECT

   96 rank_blocks: rank_block
   97            | rank_blocks rank_block

   98 $@11: ε

   99 rank_block: RANK LPAREN rank_selector RPAREN $@11 executables

  100 $@12: ε

  101 rank_block: RANK DEFAULT $@12 executables

  102 rank_selector: INT_CONST
  103              | MUL_OP

  104 case_blocks: case_block
  105            | case_blocks case_block

  106 $@13: ε

  107 case_block: CASE LPAREN expression RPAREN $@13 executables

  108 $@14: ε

  109 case_block: CASE DEFAULT $@14 executables

  110 call_stmt: CALL callable_name LPAREN argument_values RPAREN

  111 callable_name: identifier
  112              | INTRINSIC

  113 return_stmt: RETURN

  114 stop_stmt: STOP
  115          | STOP INT_CONST
  116          | STOP STRING

  117 pointer_stmt: variable_ref PTR_ASSIGN variable_ref

  118 step_opt: ε
  119         | COMMA expression

  120 print_stmt: PRINT MUL_OP COMMA print_args

  121 print_args: expression
  122           | print_args COMMA expression

  123 allocate_stmt: ALLOCATE LPAREN argument_values RPAREN

  124 deallocate_stmt: DEALLOCATE LPAREN argument_values RPAREN

  125 expression: expression ADD_OP expression
  126           | expression MUL_OP expression
  127           | expression EXPONENT expression
  128           | expression REL_OP expression
  129           | expression LOGICAL_OP expression
  130           | factor
  131           | ADD_OP expression
  132           | LOGICAL_OP expression

  133 factor: primary

  134 primary: INT_CONST
  135        | REAL_CONST
  136        | LOGICAL_CONST
  137        | STRING
  138        | complex_literal
  139        | LPAREN expression RPAREN
  140        | variable_ref primary_suffix_opt

  141 complex_literal: LPAREN expression COMMA expression RPAREN

  142 primary_suffix_opt: ε
  143                   | LPAREN argument_values RPAREN

  144 variable_ref: identifier
  145             | variable_ref DERIVED_TYPE_COMPONENT identifier

  146 subprogram_list: ε
  147                | subprogram_list subprogram

  148 $@15: ε

  149 subprogram: SUBROUTINE identifier LPAREN identifier_list_opt RPAREN $@15 program_body END SUBROUTINE opt_identifier

  150 $@16: ε

  151 subprogram: FUNCTION identifier LPAREN identifier_list_opt RPAREN $@16 program_body END FUNCTION opt_identifier

  152 $@17: ε

  153 subprogram: RECURSIVE FUNCTION identifier LPAREN identifier_list_opt RPAREN RESULT LPAREN identifier RPAREN $@17 program_body END FUNCTION opt_identifier

  154 argument_values: ε
  155                | expression
  156                | expression COMMA argument_values

  157 identifier_list_opt: ε
  158                    | identifier_list

  159 identifier: IDENTIFIER
  160           | RESULT

  161 opt_identifier: IDENTIFIER
  162               | ε

  163 type_def: TYPE DECL_SEP identifier type_def_body END_TYPE identifier

  164 type_def_body: ε
  165              | type_def_declarations

  166 type_def_declarations: type_def_declaration
  167                      | type_def_declarations type_def_declaration

  168 type_def_declaration: type_spec declaration_attributes DECL_SEP declarator_list

  169 pp_define_undef: PP_DEFINE identifier
  170                | PP_DEFINE identifier INT_CONST
  171                | PP_UNDEF identifier

  172 pp_if_block: PP_IFDEF identifier declarations pp_else_opt PP_ENDIF
  173            | PP_IFNDEF identifier declarations pp_else_opt PP_ENDIF
  174            | PP_IF identifier declarations pp_else_opt PP_ENDIF
  175            | PP_IF INT_CONST declarations pp_else_opt PP_ENDIF

  176 pp_else_opt: ε
  177            | PP_ELSE declarations


