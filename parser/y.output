Grammar

    0 $accept: start $end

    1 start: compilation_units
    2      | free_form

    3 compilation_units: compilation_unit
    4                  | compilation_units compilation_unit

    5 compilation_unit: program_unit
    6                 | module_unit

    7 free_form: preamble declarations executables

    8 program_unit: PROGRAM IDENTIFIER program_body END PROGRAM IDENTIFIER
    9             | PROGRAM IDENTIFIER program_body END PROGRAM

   10 module_unit: MODULE IDENTIFIER module_body END MODULE IDENTIFIER
   11            | MODULE IDENTIFIER module_body END MODULE

   12 program_body: preamble declarations executables contains_block

   13 module_body: preamble declarations executables contains_block

   14 contains_block: CONTAINS subprogram_list
   15               | %empty

   16 declarations: %empty
   17             | declaration declarations

   18 preamble: %empty
   19         | preamble pp_item

   20 pp_item: pp_define_undef
   21        | pp_if_block

   22 declaration: type_spec declaration_attributes DECL_SEP declarator_list
   23            | IMPLICIT NONE
   24            | USE identifier
   25            | type_def

   26 type_spec: INTEGER
   27          | REAL
   28          | LOGICAL
   29          | char_type_spec
   30          | TYPE LPAREN identifier RPAREN
   31          | CLASS identifier
   32          | COMPLEX

   33 char_type_spec: CHARACTER char_len_opt

   34 char_len_opt: %empty
   35             | LPAREN LENGTH_SPECIFIER ASSIGN char_len_value RPAREN

   36 char_len_value: COLON
   37               | INT_CONST
   38               | identifier

   39 attributes: attribute
   40           | attribute COMMA attributes

   41 attribute: ALLOCATABLE
   42          | POINTER
   43          | TARGET
   44          | INTENT LPAREN IN RPAREN
   45          | INTENT LPAREN OUT RPAREN
   46          | INTENT LPAREN INOUT RPAREN

   47 declaration_attributes: %empty
   48                       | COMMA attributes

   49 identifier_list: identifier
   50                | identifier COMMA identifier_list

   51 declarator_list: declarator
   52                | declarator COMMA declarator_list

   53 declarator: identifier array_spec_opt init_opt

   54 array_spec_opt: %empty
   55               | array_spec

   56 array_spec: LPAREN array_spec_list RPAREN

   57 array_spec_list: array_spec_item
   58                | array_spec_list COMMA array_spec_item

   59 array_spec_item: ASSUMED_RANK_SPECIFIER
   60                | COLON
   61                | expression
   62                | expression COLON
   63                | COLON expression
   64                | expression COLON expression

   65 init_opt: %empty
   66         | ASSIGN expression

   67 executables: %empty
   68            | executables executable

   69 executable: assignment_stmt
   70           | if_stmt
   71           | print_stmt
   72           | allocate_stmt
   73           | deallocate_stmt
   74           | do_stmt
   75           | dowhile_stmt
   76           | select_rank_stmt
   77           | select_stmt
   78           | call_stmt
   79           | return_stmt
   80           | stop_stmt
   81           | pointer_stmt

   82 assignment_stmt: variable_ref ASSIGN expression

   83 if_stmt: IF LPAREN expression RPAREN THEN executables ENDIF
   84        | IF LPAREN expression RPAREN THEN executables END IF
   85        | IF LPAREN expression RPAREN THEN executables ELSE executables ENDIF
   86        | IF LPAREN expression RPAREN THEN executables ELSE executables END IF

   87 do_stmt: DO IDENTIFIER ASSIGN expression COMMA expression step_opt executables END DO

   88 dowhile_stmt: DO WHILE LPAREN expression RPAREN executables END DO

   89 select_stmt: SELECT CASE LPAREN expression RPAREN case_blocks END SELECT

   90 select_rank_stmt: SELECT RANK LPAREN identifier RPAREN rank_blocks END SELECT

   91 rank_blocks: rank_block
   92            | rank_blocks rank_block

   93 rank_block: RANK LPAREN rank_selector RPAREN executables
   94           | RANK DEFAULT executables

   95 rank_selector: INT_CONST
   96              | ARITH_OP

   97 case_blocks: case_block
   98            | case_blocks case_block

   99 case_block: CASE LPAREN expression RPAREN executables
  100           | CASE DEFAULT executables

  101 call_stmt: CALL callable_name LPAREN argument_list RPAREN

  102 callable_name: identifier
  103              | INTRINSIC

  104 return_stmt: RETURN

  105 stop_stmt: STOP
  106          | STOP INT_CONST
  107          | STOP STRING

  108 pointer_stmt: variable_ref PTR_ASSIGN variable_ref

  109 step_opt: %empty
  110         | COMMA expression

  111 print_stmt: PRINT ARITH_OP COMMA print_args

  112 print_args: expression
  113           | print_args COMMA expression

  114 allocate_stmt: ALLOCATE LPAREN argument_list RPAREN

  115 deallocate_stmt: DEALLOCATE LPAREN argument_list RPAREN

  116 expression: expression ARITH_OP expression
  117           | expression EXPONENT expression
  118           | expression REL_OP expression
  119           | expression LOGICAL_OP expression
  120           | factor
  121           | ARITH_OP expression
  122           | LOGICAL_OP expression

  123 factor: primary

  124 primary: INT_CONST
  125        | REAL_CONST
  126        | LOGICAL_CONST
  127        | STRING
  128        | complex_literal
  129        | LPAREN expression RPAREN
  130        | variable_ref primary_suffix_opt

  131 complex_literal: LPAREN expression COMMA expression RPAREN

  132 primary_suffix_opt: %empty
  133                   | LPAREN argument_list RPAREN

  134 variable_ref: identifier
  135             | variable_ref DERIVED_TYPE_COMPONENT identifier

  136 subprogram_list: %empty
  137                | subprogram_list subprogram

  138 subprogram: SUBROUTINE identifier LPAREN identifier_list_opt RPAREN program_body END SUBROUTINE
  139           | SUBROUTINE identifier LPAREN identifier_list_opt RPAREN program_body END SUBROUTINE identifier
  140           | FUNCTION identifier LPAREN identifier_list_opt RPAREN program_body END FUNCTION
  141           | FUNCTION identifier LPAREN identifier_list_opt RPAREN program_body END FUNCTION identifier
  142           | RECURSIVE FUNCTION identifier LPAREN identifier_list_opt RPAREN RESULT LPAREN identifier RPAREN program_body END FUNCTION
  143           | RECURSIVE FUNCTION identifier LPAREN identifier_list_opt RPAREN RESULT LPAREN identifier RPAREN program_body END FUNCTION identifier

  144 argument_list: %empty
  145              | expression
  146              | expression COMMA argument_list

  147 identifier_list_opt: %empty
  148                    | identifier_list

  149 identifier: IDENTIFIER
  150           | RESULT

  151 type_def: TYPE DECL_SEP identifier type_def_body END_TYPE identifier

  152 type_def_body: %empty
  153              | type_def_declarations

  154 type_def_declarations: type_def_declaration
  155                      | type_def_declarations type_def_declaration

  156 type_def_declaration: type_spec declaration_attributes DECL_SEP declarator_list

  157 pp_define_undef: PP_DEFINE identifier
  158                | PP_DEFINE identifier INT_CONST
  159                | PP_UNDEF identifier

  160 pp_if_block: PP_IFDEF identifier declarations pp_else_opt PP_ENDIF
  161            | PP_IFNDEF identifier declarations pp_else_opt PP_ENDIF
  162            | PP_IF identifier declarations pp_else_opt PP_ENDIF
  163            | PP_IF INT_CONST declarations pp_else_opt PP_ENDIF

  164 pp_else_opt: %empty
  165            | PP_ELSE declarations


