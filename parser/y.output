Grammar

    0 $accept: start $end

    1 start: compilation_units
    2      | free_form

    3 compilation_units: compilation_unit
    4                  | compilation_units compilation_unit

    5 compilation_unit: program_unit
    6                 | module_unit

    7 free_form: preamble declarations executables

    8 program_unit: PROGRAM IDENTIFIER program_body END PROGRAM IDENTIFIER
    9             | PROGRAM IDENTIFIER program_body END PROGRAM

   10 module_unit: MODULE IDENTIFIER module_body END MODULE IDENTIFIER
   11            | MODULE IDENTIFIER module_body END MODULE

   12 program_body: preamble declarations executables contains_block

   13 module_body: preamble declarations executables contains_block

   14 $@1: %empty

   15 contains_block: CONTAINS $@1 subprogram_list
   16               | %empty

   17 declarations: %empty
   18             | declaration declarations

   19 preamble: %empty
   20         | preamble pp_item

   21 pp_item: pp_define_undef
   22        | pp_if_block

   23 declaration: type_spec declaration_attributes DECL_SEP declarator_list
   24            | IMPLICIT NONE
   25            | USE identifier
   26            | type_def

   27 type_spec: INTEGER
   28          | REAL
   29          | LOGICAL
   30          | char_type_spec
   31          | TYPE LPAREN identifier RPAREN
   32          | CLASS identifier
   33          | COMPLEX

   34 char_type_spec: CHARACTER char_len_opt

   35 char_len_opt: %empty
   36             | LPAREN LENGTH_SPECIFIER ASSIGN char_len_value RPAREN

   37 char_len_value: COLON
   38               | INT_CONST
   39               | identifier

   40 attributes: attribute
   41           | attribute COMMA attributes

   42 attribute: ALLOCATABLE
   43          | POINTER
   44          | TARGET
   45          | INTENT LPAREN IN RPAREN
   46          | INTENT LPAREN OUT RPAREN
   47          | INTENT LPAREN INOUT RPAREN

   48 declaration_attributes: %empty
   49                       | COMMA attributes

   50 identifier_list: identifier
   51                | identifier COMMA identifier_list

   52 declarator_list: declarator
   53                | declarator COMMA declarator_list

   54 $@2: %empty

   55 declarator: identifier array_spec_opt $@2 init_opt

   56 array_spec_opt: %empty
   57               | array_spec

   58 array_spec: LPAREN array_spec_list RPAREN

   59 array_spec_list: array_spec_item
   60                | array_spec_list COMMA array_spec_item

   61 array_spec_item: ASSUMED_RANK_SPECIFIER
   62                | COLON
   63                | expression
   64                | expression COLON
   65                | COLON expression
   66                | expression COLON expression

   67 init_opt: %empty
   68         | ASSIGN expression

   69 executables: %empty
   70            | executables executable

   71 executable: assignment_stmt
   72           | if_stmt
   73           | print_stmt
   74           | allocate_stmt
   75           | deallocate_stmt
   76           | do_stmt
   77           | dowhile_stmt
   78           | select_rank_stmt
   79           | select_stmt
   80           | call_stmt
   81           | return_stmt
   82           | stop_stmt
   83           | pointer_stmt

   84 assignment_stmt: variable_ref ASSIGN expression

   85 $@3: %empty

   86 if_stmt: IF LPAREN expression RPAREN THEN $@3 executables if_else_opt ENDIF

   87 if_else_opt: %empty

   88 $@4: %empty

   89 if_else_opt: ELSE $@4 executables

   90 $@5: %empty

   91 do_stmt: DO IDENTIFIER ASSIGN expression COMMA expression step_opt $@5 executables END DO

   92 $@6: %empty

   93 $@7: %empty

   94 dowhile_stmt: DO WHILE LPAREN $@6 expression RPAREN $@7 executables END DO

   95 $@8: %empty

   96 select_stmt: SELECT CASE LPAREN expression RPAREN $@8 case_blocks END SELECT

   97 $@9: %empty

   98 select_rank_stmt: SELECT RANK LPAREN identifier RPAREN $@9 rank_blocks END SELECT

   99 rank_blocks: rank_block
  100            | rank_blocks rank_block

  101 $@10: %empty

  102 rank_block: RANK LPAREN rank_selector RPAREN $@10 executables

  103 $@11: %empty

  104 rank_block: RANK DEFAULT $@11 executables

  105 rank_selector: INT_CONST
  106              | MUL_OP

  107 case_blocks: case_block
  108            | case_blocks case_block

  109 $@12: %empty

  110 case_block: CASE LPAREN expression RPAREN $@12 executables

  111 $@13: %empty

  112 case_block: CASE DEFAULT $@13 executables

  113 call_stmt: CALL callable_name LPAREN argument_values RPAREN

  114 callable_name: identifier
  115              | INTRINSIC

  116 return_stmt: RETURN

  117 stop_stmt: STOP
  118          | STOP INT_CONST
  119          | STOP STRING

  120 pointer_stmt: variable_ref PTR_ASSIGN variable_ref

  121 step_opt: %empty
  122         | COMMA expression

  123 print_stmt: PRINT MUL_OP COMMA print_args

  124 print_args: expression
  125           | print_args COMMA expression

  126 allocate_stmt: ALLOCATE LPAREN argument_values RPAREN

  127 deallocate_stmt: DEALLOCATE LPAREN argument_values RPAREN

  128 expression: expression ADD_OP expression
  129           | expression MUL_OP expression
  130           | expression EXPONENT expression
  131           | expression REL_OP expression
  132           | expression LOGICAL_OP expression
  133           | factor
  134           | ADD_OP expression
  135           | LOGICAL_OP expression

  136 factor: primary

  137 primary: INT_CONST
  138        | REAL_CONST
  139        | LOGICAL_CONST
  140        | STRING
  141        | complex_literal
  142        | LPAREN expression RPAREN
  143        | variable_ref primary_suffix_opt

  144 complex_literal: LPAREN expression COMMA expression RPAREN

  145 primary_suffix_opt: %empty
  146                   | LPAREN argument_values RPAREN

  147 variable_ref: identifier
  148             | variable_ref DERIVED_TYPE_COMPONENT identifier

  149 subprogram_list: %empty
  150                | subprogram_list subprogram

  151 subprogram: SUBROUTINE identifier LPAREN identifier_list_opt RPAREN program_body END SUBROUTINE
  152           | SUBROUTINE identifier LPAREN identifier_list_opt RPAREN program_body END SUBROUTINE identifier
  153           | FUNCTION identifier LPAREN identifier_list_opt RPAREN program_body END FUNCTION
  154           | FUNCTION identifier LPAREN identifier_list_opt RPAREN program_body END FUNCTION identifier
  155           | RECURSIVE FUNCTION identifier LPAREN identifier_list_opt RPAREN RESULT LPAREN identifier RPAREN program_body END FUNCTION
  156           | RECURSIVE FUNCTION identifier LPAREN identifier_list_opt RPAREN RESULT LPAREN identifier RPAREN program_body END FUNCTION identifier

  157 argument_values: %empty
  158                | expression
  159                | expression COMMA argument_values

  160 identifier_list_opt: %empty
  161                    | identifier_list

  162 identifier: IDENTIFIER
  163           | RESULT

  164 type_def: TYPE DECL_SEP identifier type_def_body END_TYPE identifier

  165 type_def_body: %empty
  166              | type_def_declarations

  167 type_def_declarations: type_def_declaration
  168                      | type_def_declarations type_def_declaration

  169 type_def_declaration: type_spec declaration_attributes DECL_SEP declarator_list

  170 pp_define_undef: PP_DEFINE identifier
  171                | PP_DEFINE identifier INT_CONST
  172                | PP_UNDEF identifier

  173 pp_if_block: PP_IFDEF identifier declarations pp_else_opt PP_ENDIF
  174            | PP_IFNDEF identifier declarations pp_else_opt PP_ENDIF
  175            | PP_IF identifier declarations pp_else_opt PP_ENDIF
  176            | PP_IF INT_CONST declarations pp_else_opt PP_ENDIF

  177 pp_else_opt: %empty
  178            | PP_ELSE declarations


