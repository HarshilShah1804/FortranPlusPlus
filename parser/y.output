Grammar

    0 $accept: start $end

    1 start: compilation_units
    2      | free_form

    3 compilation_units: compilation_unit
    4                  | compilation_units compilation_unit

    5 compilation_unit: program_unit
    6                 | module_unit

    7 free_form: preamble declarations executables

    8 program_unit: PROGRAM IDENTIFIER program_body END PROGRAM IDENTIFIER
    9             | PROGRAM IDENTIFIER program_body END PROGRAM

   10 module_unit: MODULE IDENTIFIER module_body END MODULE IDENTIFIER

   11 program_body: preamble declarations_with_modules executables contains_block

   12 module_body: preamble declarations executables contains_block

   13 contains_block: CONTAINS subprogram_list
   14               | %empty

   15 declarations: %empty
   16             | declaration declarations

   17 declarations_with_modules: %empty
   18                          | declarations_with_modules declaration
   19                          | declarations_with_modules module_unit

   20 preamble: %empty
   21         | preamble pp_item

   22 pp_item: pp_define_undef
   23        | pp_if_block

   24 declaration: type_spec declaration_attributes DECL_SEP declarator_list
   25            | IMPLICIT NONE
   26            | USE identifier
   27            | type_def

   28 type_spec: INTEGER
   29          | REAL
   30          | LOGICAL
   31          | char_type_spec
   32          | TYPE LPAREN identifier RPAREN
   33          | CLASS identifier
   34          | COMPLEX

   35 char_type_spec: CHARACTER char_len_opt

   36 char_len_opt: %empty
   37             | LPAREN LENGTH_SPECIFIER ASSIGN char_len_value RPAREN

   38 char_len_value: COLON
   39               | INT_CONST
   40               | identifier

   41 attributes: attribute
   42           | attribute COMMA attributes

   43 attribute: ALLOCATABLE
   44          | POINTER
   45          | TARGET
   46          | INTENT LPAREN IN RPAREN
   47          | INTENT LPAREN OUT RPAREN
   48          | INTENT LPAREN INOUT RPAREN

   49 declaration_attributes: %empty
   50                       | COMMA attributes

   51 identifier_list: identifier
   52                | identifier COMMA identifier_list

   53 declarator_list: declarator
   54                | declarator COMMA declarator_list

   55 declarator: identifier array_spec_opt init_opt

   56 array_spec_opt: %empty
   57               | array_spec

   58 array_spec: LPAREN array_spec_list RPAREN

   59 array_spec_list: array_spec_item
   60                | array_spec_list COMMA array_spec_item

   61 array_spec_item: ASSUMED_RANK_SPECIFIER
   62                | COLON
   63                | expression
   64                | expression COLON
   65                | COLON expression
   66                | expression COLON expression

   67 init_opt: %empty
   68         | ASSIGN expression

   69 executables: %empty
   70            | executables executable

   71 executable: assignment_stmt
   72           | if_stmt
   73           | print_stmt
   74           | allocate_stmt
   75           | deallocate_stmt
   76           | do_stmt
   77           | dowhile_stmt
   78           | select_rank_stmt
   79           | select_stmt
   80           | call_stmt
   81           | return_stmt
   82           | stop_stmt
   83           | pointer_stmt

   84 assignment_stmt: variable_ref ASSIGN expression

   85 if_stmt: IF LPAREN expression RPAREN THEN executables ENDIF
   86        | IF LPAREN expression RPAREN THEN executables END IF
   87        | IF LPAREN expression RPAREN THEN executables ELSE executables ENDIF
   88        | IF LPAREN expression RPAREN THEN executables ELSE executables END IF

   89 do_stmt: DO IDENTIFIER ASSIGN expression COMMA expression step_opt executables END DO

   90 dowhile_stmt: DO WHILE LPAREN expression RPAREN executables END DO

   91 select_stmt: SELECT CASE LPAREN expression RPAREN case_blocks END SELECT

   92 select_rank_stmt: SELECT RANK LPAREN identifier RPAREN rank_blocks END SELECT

   93 rank_blocks: rank_block
   94            | rank_blocks rank_block

   95 rank_block: RANK LPAREN rank_selector RPAREN executables
   96           | RANK DEFAULT executables

   97 rank_selector: INT_CONST
   98              | ARITH_OP

   99 case_blocks: case_block
  100            | case_blocks case_block

  101 case_block: CASE LPAREN expression RPAREN executables
  102           | CASE DEFAULT executables

  103 call_stmt: CALL callable_name LPAREN argument_list RPAREN

  104 callable_name: identifier
  105              | INTRINSIC

  106 return_stmt: RETURN

  107 stop_stmt: STOP
  108          | STOP INT_CONST
  109          | STOP STRING

  110 pointer_stmt: variable_ref PTR_ASSIGN variable_ref

  111 step_opt: %empty
  112         | COMMA expression

  113 print_stmt: PRINT ARITH_OP COMMA print_args

  114 print_args: expression
  115           | print_args COMMA expression

  116 allocate_stmt: ALLOCATE LPAREN argument_list RPAREN

  117 deallocate_stmt: DEALLOCATE LPAREN argument_list RPAREN

  118 expression: expression ARITH_OP expression
  119           | expression EXPONENT expression
  120           | expression REL_OP expression
  121           | expression LOGICAL_OP expression
  122           | factor
  123           | ARITH_OP expression
  124           | LOGICAL_OP expression

  125 factor: primary

  126 primary: INT_CONST
  127        | REAL_CONST
  128        | LOGICAL_CONST
  129        | STRING
  130        | complex_literal
  131        | LPAREN expression RPAREN
  132        | variable_ref primary_suffix_opt

  133 complex_literal: LPAREN expression COMMA expression RPAREN

  134 primary_suffix_opt: %empty
  135                   | LPAREN argument_list RPAREN

  136 variable_ref: identifier
  137             | variable_ref DERIVED_TYPE_COMPONENT IDENTIFIER

  138 subprogram_list: %empty
  139                | subprogram_list subprogram

  140 subprogram: SUBROUTINE identifier LPAREN identifier_list_opt RPAREN program_body END SUBROUTINE
  141           | SUBROUTINE identifier LPAREN identifier_list_opt RPAREN program_body END SUBROUTINE identifier
  142           | FUNCTION identifier LPAREN identifier_list_opt RPAREN program_body END FUNCTION
  143           | FUNCTION identifier LPAREN identifier_list_opt RPAREN program_body END FUNCTION identifier
  144           | RECURSIVE FUNCTION identifier LPAREN identifier_list_opt RPAREN RESULT LPAREN identifier RPAREN program_body END FUNCTION
  145           | RECURSIVE FUNCTION identifier LPAREN identifier_list_opt RPAREN RESULT LPAREN identifier RPAREN program_body END FUNCTION identifier

  146 argument_list: %empty
  147              | expression
  148              | expression COMMA argument_list

  149 identifier_list_opt: %empty
  150                    | identifier_list

  151 identifier: IDENTIFIER
  152           | RESULT

  153 type_def: TYPE DECL_SEP identifier type_def_body END_TYPE identifier

  154 type_def_body: %empty
  155              | type_def_declarations

  156 type_def_declarations: type_def_declaration
  157                      | type_def_declarations type_def_declaration

  158 type_def_declaration: type_spec declaration_attributes DECL_SEP declarator_list

  159 pp_define_undef: PP_DEFINE identifier
  160                | PP_DEFINE identifier INT_CONST
  161                | PP_UNDEF identifier

  162 pp_if_block: PP_IFDEF identifier declarations pp_else_opt PP_ENDIF
  163            | PP_IFNDEF identifier declarations pp_else_opt PP_ENDIF
  164            | PP_IF identifier declarations pp_else_opt PP_ENDIF
  165            | PP_IF INT_CONST declarations pp_else_opt PP_ENDIF

  166 pp_else_opt: %empty
  167            | PP_ELSE declarations


